{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBucketForSmokeTest",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::wmata-dashboard-backups"
    },
    {
      "Sid": "WriteBackupsAndArchive",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::wmata-dashboard-backups/wmata-db-backups/*",
        "arn:aws:s3:::wmata-dashboard-backups/wmata-vp-archive/*"
      ]
    }
  ]
}
